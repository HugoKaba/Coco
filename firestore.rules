rules_version = '2';

// Règles de base : tout accès nécessite un utilisateur authentifié.
// (Suffisant pour le développement local via l'émulateur. À durcir par
//  collection avant une vraie mise en production.)
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
